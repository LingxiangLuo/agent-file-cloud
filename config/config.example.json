{
  "version": "4.0.0",
  "created": "2026-03-30",
  
  "api": {
    "dashscope_api_key": "YOUR_DASHSCOPE_API_KEY_HERE",
    "embedding_model": "text-embedding-v4",
    "dimension": 1024
  },
  
  "qiniu": {
    "access_key": "YOUR_QINIU_ACCESS_KEY_HERE",
    "secret_key": "YOUR_QINIU_SECRET_KEY_HERE",
    "bucket": "your-bucket-name",
    "domain": "https://your-cdn-domain.com",
    "graph_domain": "http://your-graph-domain.com",
    "default_expiry_days": 7
  },
  
  "directories": {
    "inbox": "workspace/inbox",
    "archive": "workspace/archive",
    "temp": "workspace/temp"
  },
  
  "storage_policy": {
    "hot_extensions": [".py", ".sh", ".js", ".ts", ".go", ".rs", ".yaml", ".yml"],
    "cold_extensions": [".md", ".pdf", ".png", ".jpg", ".jpeg", ".gif", ".webp", ".mp4", ".docx", ".pptx", ".xlsx"],
    "warm_extensions": [".json", ".xml", ".log", ".txt", ".csv"]
  },
  
  "features": {
    "enable_semantic_search": true,
    "enable_auto_upload": true,
    "enable_duplicate_check": true,
    "enable_version_control": true
  }
}
